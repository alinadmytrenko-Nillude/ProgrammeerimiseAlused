import pygame          # Impordime pygame mooduli, et saaksime mängu teha
import random          # Impordime random mooduli, et saaksime juhuslikke väärtusi

pygame.init()          # Käivitame pygame'i

# Värvid
LIGHT_BLUE = (153, 204, 255)   # Määrame tausta värvi (helesinine)

# Ekraani seaded
SCREEN_WIDTH = 640             # Määrame akna laiuse
SCREEN_HEIGHT = 480            # Määrame akna kõrguse
screen = pygame.display.set_mode([SCREEN_WIDTH, SCREEN_HEIGHT])  # Loome mängu akna
pygame.display.set_caption("Hiir - Kliki ja loo ringe!")         # Paneme aknale pealkirja
clock = pygame.time.Clock()    # Loome kella, et kontrollida mängu kiirust

# Ringide nimekiri: [x, y, radius, color]
circles = []                   # Tühi nimekiri, kuhu salvestame kõik ringid
MAX_CIRCLES = 10               # Maksimaalne ringide arv korraga

running = True                 # Muutuja, mis hoiab mängu töös
while running:                 # Põhiloop, mis töötab seni kuni mäng pole lõpetatud
    clock.tick(60)             # Piirame mängu kiirust 60 kaadrini sekundis

    for event in pygame.event.get():   # Kontrollime kõiki sündmusi (kliki, sulgemine jne)
        if event.type == pygame.QUIT:  # Kui kasutaja vajutab akna ristile
            running = False            # Lõpetame mängu

        if event.type == pygame.MOUSEBUTTONDOWN:  # Kui hiirega klikitakse
            x, y = event.pos                  # Saame kliki koordinaadid

            # Juhuslik värv
            color = (                         # Loome juhusliku värvi
                random.randint(30, 220),      # Punane komponent
                random.randint(30, 220),      # Roheline komponent
                random.randint(30, 220)       # Sinine komponent
            )
            
            # Juhuslik raadius vahemikus 10–60 pikslit
            radius = random.randint(10, 60)   # Iga ring on erineva suurusega

            # Lisa ring
            circles.append([x, y, radius, color])  # Lisame uue ringi nimekirja

            # Kui rohkem kui 10 ringi, eemalda vanim
            if len(circles) > MAX_CIRCLES:     # Kontrollime, kas ringe on liiga palju
                circles.pop(0)                 # Kustutame vanima ringi

    # Joonista taust ja ringid
    screen.fill(LIGHT_BLUE)        # Täidame ekraani helesinise värviga

    for c in circles:              # Käime läbi kõik ringid
        pygame.draw.circle(        # Joonistame ringi
            screen,                # Millisele pinnale
            c[3],                  # Värv
            (int(c[0]), int(c[1])),# Keskpunkt (x, y)
            int(c[2]),             # Raadius
            2                      # Joone paksus (2 pikslit)
        )

    pygame.display.flip()          # Uuendame ekraani (näitame joonistatud asju)

pygame.quit()                      # Lõpetame pygame'i töö
