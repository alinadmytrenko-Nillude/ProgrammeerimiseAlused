# GIF-spraitide registreerimine βÄî vΟΒetud Script 7-st (kucukpac.gif, kirmizi.gif)
# ---------------------------------------------------------------------------

GIF_PACMAN = "kucukpac.gif"  # Pac-Mani GIF-spraidi failinimi
GIF_GHOST  = "kirmizi.gif"   # kummituse GIF-spraidi failinimi


def register_shapes(screen):
    """Registreerib GIF-spraidid turtle'i ekraanil βÄî Script 7 idee."""
    screen.register_shape(GIF_PACMAN)  # registreerib Pac-Mani pildi
    screen.register_shape(GIF_GHOST)   # registreerib kummituse pildi


# ---------------------------------------------------------------------------
# MΟΛngija klass βÄî OOP struktuur Script 7-st, GIF-spraait Script 7-st
# ---------------------------------------------------------------------------
class Player(turtle.Turtle):
    """Pac-Man mΟΛngija GIF-spraidiga kucukpac.gif (Script 7)."""

    def __init__(self, x, y):
        super().__init__()              # turtle.Turtle algvΟΛΟΛrtustamine
        self.shape(GIF_PACMAN)          # mΟΛΟΛrab GIF-pildi kujuks
        self.penup()                    # ei joonista liikudes joont
        self.speed(0)                   # kiirim animatsioon
        self.goto(x, y)                 # liigub alguspositsioonile
        self.direction = "stop"         # algsuund on peatatud

    def go_up(self):                    # mΟΛΟΛrab liikumissuunaks ΟΦles
        self.direction = "up"

    def go_down(self):                  # mΟΛΟΛrab liikumissuunaks alla
        self.direction = "down"

    def go_left(self):                  # mΟΛΟΛrab liikumissuunaks vasakule
        self.direction = "left"

    def go_right(self):                 # mΟΛΟΛrab liikumissuunaks paremale
        self.direction = "right"

    def next_position(self):
        """Arvutab jΟΛrgmise positsiooni ilma tegeliku liikumiseta."""
        x, y = self.xcor(), self.ycor()         # praegused koordinaadid
        if   self.direction == "up":    y += TILE_SIZE   # ΟΦles βÄî y suureneb
        elif self.direction == "down":  y -= TILE_SIZE   # alla βÄî y vΟΛheneb
        elif self.direction == "left":  x -= TILE_SIZE   # vasakule βÄî x vΟΛheneb
        elif self.direction == "right": x += TILE_SIZE   # paremale βÄî x suureneb
        return x, y                             # tagastab uue positsiooni

    def is_near(self, other):
        """
        Kontrollib lΟΛhedust kauguse ruudu kaudu ilma aeglase ruutjuureta βÄî Script 7.
        Tagastab True kui 'other' on lΟΛhemal kui CHASE_DISTANCE_SQ.
        """
        dx = self.xcor() - other.xcor()         # horisontaalne kaugus
        dy = self.ycor() - other.ycor()         # vertikaalne kaugus
        return dx * dx + dy * dy < CHASE_DISTANCE_SQ  # kauguse ruut


# ---------------------------------------------------------------------------
# Kummituse klass βÄî OOP ja jΟΛlitamise tehisintellekt Script 7-st, 4 vΟΛrvi Script 8-st
# ---------------------------------------------------------------------------
class Ghost(turtle.Turtle):
    """
    Kummitus GIF-spraidiga kirmizi.gif (Script 7).
    Juhuslik liikumine + mΟΛngija jΟΛlitamine lΟΛheduses (Script 7).
    Iga kummitus liigub iseseisvalt ontimer kaudu (Script 7).
    """

    def __init__(self, x, y, color, wall_set, player_ref, speed_ms=200):
        super().__init__()                      # turtle.Turtle algvΟΛΟΛrtustamine
        self.shape(GIF_GHOST)                   # GIF-spraait Script 7-st
        self.color(color)                       # kummituse vΟΛrv (punane/roosa/oran≈Ψ/helesinine)
        self.penup()                            # ei joonista liikudes joont
        self.speed(0)                           # kiirim animatsioon
        self.goto(x, y)                         # liigub alguspositsioonile
        self.wall_set   = wall_set              # seinte koordinaatide hulk
        self.player_ref = player_ref            # viide mΟΛngijale (jΟΛlitamiseks)
        self.speed_ms   = speed_ms              # liikumise algkiirus millisekundites
        self.direction  = random.choice(["up", "down", "left", "right"])  # juhuslik algsuund
        self.active     = True                  # True kui mΟΛng kΟΛib

    def move(self):
        """Ο€ks samm: jΟΛlitamine vΟΒi juhuslik liikumine, seejΟΛrel ontimer."""
        if not self.active:                     # kui mΟΛng on lΟΒppenud, ei liigu
            return

        px, py = self.player_ref.xcor(), self.player_ref.ycor()  # mΟΛngija koordinaadid
        gx, gy = self.xcor(), self.ycor()       # kummituse praegused koordinaadid

        # JΟΛlitamise tehisintellekt βÄî Script 7: muudab suunda mΟΛngija poole kui lΟΛhedal
        if self.player_ref.is_near(self):
            if   px < gx: self.direction = "left"   # mΟΛngija on vasakul
            elif px > gx: self.direction = "right"  # mΟΛngija on paremal
            elif py > gy: self.direction = "up"     # mΟΛngija on ΟΦleval
            else:         self.direction = "down"   # mΟΛngija on all

        dx, dy = self._delta(self.direction)    # arvutab nihke praeguse suuna jΟΛrgi
        nx, ny = gx + dx, gy + dy              # jΟΛrgmise sammu koordinaadid

        if (nx, ny) not in self.wall_set:       # kui teel pole seina
            self.goto(nx, ny)                   # liigub jΟΛrgmisesse positsioonile
        else:
            # Sein ees βÄî valib juhusliku vaba suuna (Script 7)
            candidates = []                     # vabade suundade loend
            for d in ("up", "down", "left", "right"):   # kontrollib kΟΒiki suundi
                ddx, ddy = self._delta(d)       # suuna nihe
                cx, cy = gx + ddx, gy + ddy    # kontrollitav positsioon
                if (cx, cy) not in self.wall_set:       # kui sein puudub
                    candidates.append((d, cx, cy))      # lisab vΟΒimalike hulka
            if candidates:                      # kui vabad suunad olemas
                self.direction, nx, ny = random.choice(candidates)  # valib juhusliku
                self.goto(nx, ny)               # liigub valitud suunas

        # Teleportatsioon lΟΛbi kΟΦlgservade βÄî Script 8
        if   self.xcor() >  190: self.goto(-190, self.ycor())  # paremast servast vasakule
        elif self.xcor() < -190: self.goto( 190, self.ycor())  # vasakust servast paremale

        # Juhuslik taimer iga sammu jaoks βÄî Script 7: random.randint(100, 300)
        turtle.ontimer(self.move, t=random.randint(100, 300))  # kΟΛivitab jΟΛrgmise sammu

    @staticmethod
    def _delta(direction):
        """Tagastab nihke (dx, dy) antud suuna jaoks."""
        return {
            "up":    (0,  TILE_SIZE),   # ΟΦles liikumine
            "down":  (0, -TILE_SIZE),   # alla liikumine
            "left":  (-TILE_SIZE, 0),   # vasakule liikumine
            "right": ( TILE_SIZE, 0),   # paremale liikumine
        }.get(direction, (0, 0))        # tundmatu suund βÄî ei liigu

    def deactivate(self):
        """Peatab liikumise ja peidab kummituse mΟΛngu lΟΒppedes."""
        self.active = False     # keelab edasise liikumise
        self.hideturtle()       # peidab kummituse ekraanil


