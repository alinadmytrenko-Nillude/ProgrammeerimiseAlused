# ---------------------------------------------------------------------------
# Tulemustabeli klass βÄî Script 8-st: skoor ekraani vasakus ΟΦlanurgas
# ---------------------------------------------------------------------------
class ScoreBoard(turtle.Turtle):
    """Kuvab praegust skoori ekraani vasakus ΟΦlanurgas (Script 8)."""

    def __init__(self):
        super().__init__()      # turtle.Turtle algvΟΛΟΛrtustamine
        self.speed(0)           # kiirim animatsioon
        self.color("white")     # valge tekst mustal taustal
        self.penup()            # ei joonista joont
        self.hideturtle()       # peidab kilpkonna ikoonni
        self.score = 0          # algskoor on null
        self._draw()            # kuvab skoori kohe alguses

    def add(self, points):
        """Lisab punktid ja uuendab ekraanil kuvatavat skoori."""
        self.score += points    # lisab punktid kogusummale
        self._draw()            # joonistab uuendatud skoori

    def _draw(self):
        """Kustutab vana skoori ja kirjutab uue."""
        self.goto(-290, 280)    # liigub vasakusse ΟΦlanurka
        self.clear()            # kustutab eelmise teksti
        self.write(f"Score: {self.score}", align="left", font=("Arial", 16, "normal"))  # kirjutab skoori


# ---------------------------------------------------------------------------
# Taseme ehitamise funktsioon βÄî loeb MAP-i ja loob kΟΒik objektid
# ---------------------------------------------------------------------------
def build_level(map_data):
    """
    Loeb MAP-i ja loob seinad, toidu, boonused, kummitused ja mΟΛngija.
    Tagastab: wall_set, player, food_list, bonus_list, ghost_list
    """
    wall_set     = set()    # seinte koordinaadid kiireks kontrolliks O(1) βÄî Script 7
    food_list    = []       # toidu objektide loend
    bonus_list   = []       # boonuste objektide loend
    ghost_spawn  = []       # kummituste algusandmete loend (x, y, vΟΛrv)
    player_start = (0, 0)   # mΟΛngija alguspositsioon

    pen = turtle.Turtle()   # mall seinte kloonimiseks
    pen.shape("square")     # ruudukujuline sein
    pen.color("blue")       # sinine vΟΛrv
    pen.penup()             # ei joonista joont
    pen.speed(0)            # kiirim animatsioon
    pen.hideturtle()        # peidab malli

    for row_i, row in enumerate(map_data):          # itereerib ΟΦle kaardi ridade
        for col_i, cell in enumerate(row):          # itereerib ΟΦle rea lahtrite
            sx, sy = tile_to_screen(col_i, row_i)  # teisendab ekraanikoordinaatideks
            if cell == '1':                         # sein
                block = pen.clone()                 # loob seina klooni
                block.goto(sx, sy)                  # asetab seina ΟΒigesse kohta
                block.showturtle()                  # kuvab seina ekraanil
                wall_set.add((sx, sy))              # lisab koordinaadi seinte hulka
            elif cell == ' ':                       # tΟΦhi lahter βÄî tekib toit
                food_list.append(Food(sx, sy))      # loob toidu objekti
            elif cell == 'B':                       # boonuse lahter
                bonus_list.append(Bonus(sx, sy))    # loob boonuse objekti
            elif cell == 'P':                       # mΟΛngija alguspositsioon
                player_start = (sx, sy)             # salvestab alguskoordinaadid
            elif cell == 'r':                       # punane kummitus
                ghost_spawn.append((sx, sy, "red"))
            elif cell == 'p':                       # roosa kummitus
                ghost_spawn.append((sx, sy, "pink"))
            elif cell == 'o':                       # oran≈Ψ kummitus
                ghost_spawn.append((sx, sy, "orange"))
            elif cell == 's':                       # helesinine kummitus
                ghost_spawn.append((sx, sy, "lightblue"))

    player = Player(*player_start)  # loob mΟΛngija alguspositsioonile

    # Loob kummitused βÄî 4 vΟΛrvi Script 8-st, OOP ja ontimer Script 7-st
    ghost_list = [
        Ghost(x, y, color, wall_set, player, speed_ms=random.randint(180, 280))
        for x, y, color in ghost_spawn  # iga kummitus erineva alguskiirusega
    ]

    return wall_set, player, food_list, bonus_list, ghost_list  # tagastab kΟΒik objektid


# ---------------------------------------------------------------------------
# MΟΛngu lΟΒpetamise funktsioon βÄî Script 8-st
# ---------------------------------------------------------------------------
def game_over(player, ghost_list, score_board, message):
    """Peidab tegelased ja kuvab lΟΒpusΟΒnumi ekraani keskele (Script 8)."""
    player.hideturtle()             # peidab mΟΛngija
    for ghost in ghost_list:        # itereerib ΟΦle kΟΒigi kummituste
        ghost.deactivate()          # peatab kummituse liikumise
    score_board.goto(0, 0)          # liigub ekraani keskele
    score_board.write(message, align="center", font=("Arial", 24, "bold"))  # kuvab sΟΒnumi


# ---------------------------------------------------------------------------
# Peamine mΟΛngutsΟΦkkel βÄî kutsutakse iga 100 ms jΟΛrel
# ---------------------------------------------------------------------------
def game_loop(player, wall_set, food_list, bonus_list, ghost_list, score_board):
    """Liigutab mΟΛngijat ja kontrollib kΟΒiki kokkupΟΒrkeid."""

    nx, ny = player.next_position()     # arvutab jΟΛrgmise positsiooni

    # Seina kokkupΟΒrke kontroll koordinaatide set kaudu βÄî Script 7 (O(1))
    if (nx, ny) not in wall_set:        # kui teel pole seina
        player.goto(nx, ny)             # liigub jΟΛrgmisesse positsioonile

    # Teleportatsioon lΟΛbi kΟΦlgservade βÄî Script 8
    if   player.xcor() >  190:                      # parempoolsest servast vΟΛlja
        player.goto(-190, player.ycor())             # ilmub vasakust servast
    elif player.xcor() < -190:                      # vasakpoolsest servast vΟΛlja
        player.goto( 190, player.ycor())             # ilmub paremast servast

    # Toidu kogumine (+10 punkti) βÄî Script 8
    for food in food_list[:]:                       # kopeerib loendi muutmiseks
        if player.distance(food) < TILE_SIZE:       # mΟΛngija on toidu lΟΛhedal
            food.destroy()                          # eemaldab toidu ekraanilt
            food_list.remove(food)                  # eemaldab loendist
            score_board.add(Food.POINTS)            # lisab 10 punkti
            # Skoori vΟΛljastamine konsooli βÄî Script 7: print() iga kogumise korral
            print("Score: {}".format(score_board.score))

    # Boonuse kogumine (+50 punkti) βÄî Script 8
    for bonus in bonus_list[:]:                     # kopeerib loendi muutmiseks
        if player.distance(bonus) < TILE_SIZE:      # mΟΛngija on boonuse lΟΛhedal
            bonus.destroy()                         # eemaldab boonuse ekraanilt
            bonus_list.remove(bonus)                # eemaldab loendist
            score_board.add(Bonus.POINTS)           # lisab 50 punkti
            # Skoori vΟΛljastamine konsooli βÄî Script 7
            print("Score (bonus): {}".format(score_board.score))

    # Kummitusega kokkupΟΒrge βÜ£ mΟΛng lΟΒpeb βÄî Script 8
    for ghost in ghost_list:                        # kontrollib kΟΒiki kummitusi
        if player.distance(ghost) < TILE_SIZE + 5:  # mΟΛngija puutub kummitust
            # Kaotuse vΟΛljastamine konsooli βÄî Script 7: print("Oyuncu kaybetti!")
            print("Game Over! Pac-Man caught!")
            game_over(player, ghost_list, score_board, "Game Over! Pac-Man caught!")
            return                                  # lΟΒpetab tsΟΦkli

    # VΟΒidutingimus: kogu toit ja boonused sΟΕΟΕdud βÄî Script 8
    if not food_list and not bonus_list:            # kui mΟΒlemad loendid tΟΦhjad
        # VΟΒidu vΟΛljastamine konsooli βÄî Script 7
        print("You Win! All pellets eaten! Final score: {}".format(score_board.score))
        game_over(player, ghost_list, score_board, "You Win! All pellets eaten!")
        return                                      # lΟΒpetab tsΟΦkli

    screen.update()                                 # uuendab ekraani
    turtle.ontimer(                                 # planeerib jΟΛrgmise tsΟΦkli
        lambda: game_loop(player, wall_set, food_list, bonus_list, ghost_list, score_board),
        t=100,                                      # 100 ms pΟΛrast
    )


# ---------------------------------------------------------------------------
# Programmi sisendpunkt
# ---------------------------------------------------------------------------
def main():
    global screen  # globaalne muutuja ekraani jaoks

    screen = turtle.Screen()                        # loob mΟΛnguakna
    screen.setup(width=SCREEN_WIDTH, height=SCREEN_HEIGHT)  # mΟΛΟΛrab akna suuruse
    screen.bgcolor("black")                         # must taust
    screen.title("Pac-Man βÄî Combined Edition")      # akna pealkiri
    screen.tracer(0)                                # lΟΦlitab automaatse uuenduse vΟΛlja

    register_shapes(screen)                         # registreerib GIF-spraidid

    wall_set, player, food_list, bonus_list, ghost_list = build_level(MAP)  # ehitab taseme
    score_board = ScoreBoard()                      # loob tulemustabeli

    # Klahvide sidumine βÄî nooleklahvid JA WASD βÄî Script 7
    screen.listen()                                 # aktiveerib klahvide kuulamise
    screen.onkeypress(player.go_up,    "Up")        # nooleklahv ΟΦles
    screen.onkeypress(player.go_down,  "Down")      # nooleklahv alla
    screen.onkeypress(player.go_left,  "Left")      # nooleklahv vasakule
    screen.onkeypress(player.go_right, "Right")     # nooleklahv paremale
    screen.onkeypress(player.go_up,    "w")         # W-klahv ΟΦles
    screen.onkeypress(player.go_down,  "s")         # S-klahv alla
    screen.onkeypress(player.go_left,  "a")         # A-klahv vasakule
    screen.onkeypress(player.go_right, "d")         # D-klahv paremale

    # KΟΛivitab iga kummituse iseseisvalt ontimer kaudu βÄî Script 7
    for ghost in ghost_list:                        # itereerib ΟΦle kΟΒigi kummituste
        turtle.ontimer(ghost.move, t=250)           # esimene samm 250 ms pΟΛrast

    game_loop(player, wall_set, food_list, bonus_list, ghost_list, score_board)  # kΟΛivitab mΟΛngu

    turtle.done()  # hoiab akna lahti kuni sulgemiseni


if __name__ == "__main__":  # kΟΛivitab ainult otse kΟΛivitamisel, mitte importimisel
    main()
