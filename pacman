TILE_SIZE     = 20   # ΟΦhe lahtri suurus pikslites
SCREEN_WIDTH  = 600  # mΟΛnguakna laius
SCREEN_HEIGHT = 600  # mΟΛnguakna kΟΒrgus

MAP_WIDTH  = len(MAP[0]) * TILE_SIZE          # kaardi laius pikslites
MAP_HEIGHT = len(MAP)    * TILE_SIZE          # kaardi kΟΒrgus pikslites
START_X    = -MAP_WIDTH  // 2                 # kaardi vasak serv ekraanil
START_Y    =  MAP_HEIGHT // 2 - TILE_SIZE     # kaardi ΟΦlemine serv ekraanil

# Kauguse ruut, mille juures kummitus lΟΦlitub jΟΛlitamisre≈Ψiimile βÄî Script 7-st
CHASE_DISTANCE_SQ = 5500  # ligikaudu 74 pikslit


def tile_to_screen(col, row):
    """Teisendab kaardi lahtri indeksid ekraanikoordinaatideks."""
    return START_X + col * TILE_SIZE, START_Y - row * TILE_SIZE  # tagastab (x, y)


