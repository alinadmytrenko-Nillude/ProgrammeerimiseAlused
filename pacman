# Toidu klass βÄî Script 8-st: valge ringike, +10 punkti
# ---------------------------------------------------------------------------
class Food(turtle.Turtle):
    """Tavaline toit βÄî valge ringike, vΟΛΟΛrt 10 punkti (Script 8)."""

    POINTS = 10  # toidu punktivΟΛΟΛrtus

    def __init__(self, x, y):
        super().__init__()          # turtle.Turtle algvΟΛΟΛrtustamine
        self.shape("circle")        # ringikujuline
        self.color("white")         # valge vΟΛrv
        self.shapesize(0.4, 0.4)    # vΟΛike suurus
        self.penup()                # ei joonista joont
        self.speed(0)               # kiirim animatsioon
        self.goto(x, y)             # asetab toiduobjekti kaardile

    def destroy(self):
        """Eemaldab toidu ekraanilt pΟΛrast kogumist."""
        self.goto(2000, 2000)   # liigub ekraanist vΟΛlja
        self.hideturtle()       # peidab objekti


