import pygame, sys, random  # import pygame for graphics, sys to exit, random for random numbers
pygame.init()  # initialize all pygame modules

# --- screen settings ---
screenX, screenY = 640, 480  # set window width and height in pixels
screen = pygame.display.set_mode([screenX, screenY])  # create the game window
pygame.display.set_caption("Vastutulevad autod")  # set the window title bar text
clock = pygame.time.Clock()  # create a clock object to control frame rate

# --- road boundaries (adjust if needed) ---
ROAD_LEFT  = 155  # x coordinate where the left edge of the road starts
ROAD_RIGHT = 425  # x coordinate where the right edge of the road ends (minus car width)

# --- load images ---
taust = pygame.image.load("bg_rally.jpg")  # load the background road image from file
taust = pygame.transform.scale(taust, [screenX, screenY])  # scale background to fit the window

punane_auto = pygame.image.load("f1_red.png")  # load the red player car image from file
punane_auto = pygame.transform.scale(punane_auto, [60, 100])  # resize red car to 60x100 pixels

sinine_auto = pygame.image.load("f1_blue.png")  # load the blue enemy car image from file
sinine_auto = pygame.transform.scale(sinine_auto, [60, 100])  # resize blue car to 60x100 pixels
sinine_auto = pygame.transform.flip(sinine_auto, False, True)  # flip blue car vertically so it faces downward

# --- fonts ---
font     = pygame.font.SysFont("Arial", 28, bold=True)  # small bold font used for score and hints
font_big = pygame.font.SysFont("Arial", 60, bold=True)  # large bold font used for title and game over
font_med = pygame.font.SysFont("Arial", 36, bold=True)  # medium bold font used for the start screen prompt

# START SCREEN
waiting = True   # flag that keeps the start screen loop running
blink_timer = 0  # counter that tracks frames for the blinking text effect
show_blink = True  # controls whether the blinking prompt text is currently visible

while waiting:  # keep looping until the player presses SPACE
    clock.tick(60)  # limit the loop to 60 frames per second
    blink_timer += 1  # increase blink counter by 1 each frame
    if blink_timer >= 30:  # every 30 frames (~0.5 seconds) toggle the blinking text
        show_blink = not show_blink  # switch the prompt text on or off
        blink_timer = 0  # reset the counter back to zero

    for event in pygame.event.get():  # loop through all events that happened this frame
        if event.type == pygame.QUIT:  # if the user clicked the window close button
            sys.exit()  # exit the program immediately
        if event.type == pygame.KEYDOWN:  # if any keyboard key was pressed
            if event.key == pygame.K_SPACE:  # if the pressed key is SPACE
                waiting = False  # stop the start screen loop and begin the game
            if event.key == pygame.K_ESCAPE:  # if the pressed key is ESCAPE
                sys.exit()  # exit the program immediately

    screen.blit(taust, (0, 0))  # draw the road background image onto the screen

    overlay = pygame.Surface((screenX, screenY), pygame.SRCALPHA)  # create a new surface that supports transparency
    overlay.fill((0, 0, 0, 160))  # fill it with semi-transparent black (alpha = 160)
    screen.blit(overlay, (0, 0))  # draw the dark overlay on top of the background

    title_surf  = font_big.render("VASTUTULEVAD", True, (255, 220, 0))  # render the first title word in yellow
    title_surf2 = font_big.render("AUTOD",        True, (255, 220, 0))  # render the second title word in yellow
    screen.blit(title_surf,  (screenX // 2 - title_surf.get_width()  // 2, 100))  # draw first word centered at y=100
    screen.blit(title_surf2, (screenX // 2 - title_surf2.get_width() // 2, 165))  # draw second word centered at y=165

    ctrl_surf = font.render("← → : liikumine", True, (200, 200, 200))  # render the controls hint in grey
    screen.blit(ctrl_surf, (screenX // 2 - ctrl_surf.get_width() // 2, 280))  # draw controls hint centered at y=280

    if show_blink:  # only draw the prompt text when it is in the visible phase
        start_surf = font_med.render("Vajuta SPACE alustamiseks", True, (255, 255, 255))  # render the start prompt in white
        screen.blit(start_surf, (screenX // 2 - start_surf.get_width() // 2, 360))  # draw prompt centered at y=360

    pygame.display.flip()  # update the full display so everything drawn this frame becomes visible

# ============================================================
# --- GAME INIT (reset state after start screen) ---
# ============================================================

redX = screenX // 2 - 30  # place red car horizontally in the center of the road
redY = screenY - 120  # place red car near the bottom of the screen
car_speed = 5  # number of pixels the red car moves left or right per frame

autod = []  # empty list that will hold data for all blue cars
lanes = [180, 300, 420]  # x positions of the three road lanes
for lane in lanes:  # create one blue car for each lane
    autod.append([lane, random.randint(-800, -200), random.randint(1, 3)])  # [x, y above screen, speed]

skoor = 0  # set the starting score to zero

gameover = False  # flag that keeps the main game loop running
while not gameover:  # loop until a collision ends the game
    clock.tick(60)  # limit the loop to 60 frames per second

    for i in pygame.event.get():  # process all events in the queue
        if i.type == pygame.QUIT:  # if the window close button is clicked
            sys.exit()  # exit the program

    keys = pygame.key.get_pressed()  # read the current state of all keyboard keys
    if keys[pygame.K_LEFT] and redX > ROAD_LEFT:  # if LEFT arrow is held and car is not at the left edge
        redX -= car_speed  # move the red car to the left
    if keys[pygame.K_RIGHT] and redX < ROAD_RIGHT:  # if RIGHT arrow is held and car is not at the right edge
        redX += car_speed  # move the red car to the right

    screen.blit(taust, (0, 0))  # redraw the background each frame to erase the previous frame

    screen.blit(punane_auto, (redX, redY))  # draw the red car at its current position
    red_rect = punane_auto.get_rect()  # get a rectangle the same size as the red car image
    red_rect.topleft = (redX, redY)  # position the rectangle at the red car's top-left corner

    for i in range(len(autod)):  # loop through every blue car in the list
        screen.blit(sinine_auto, (autod[i][0], autod[i][1]))  # draw the blue car at its current position
        autod[i][1] += autod[i][2]  # move the blue car downward by its speed value

        blue_rect = sinine_auto.get_rect()  # get a rectangle the same size as the blue car image
        blue_rect.topleft = (autod[i][0], autod[i][1])  # position the rectangle at the blue car's top-left corner

        if red_rect.colliderect(blue_rect):  # check if the red car rectangle overlaps the blue car rectangle
            gameover = True  # collision detected — set flag to end the game

        if autod[i][1] > screenY:  # if the blue car has moved past the bottom of the screen
            skoor += 1  # the player successfully avoided this car — add 1 point
            autod[i][1] = random.randint(-800, -200)  # respawn the car far above the screen
            autod[i][2] = random.randint(1, 3)  # give it a new random speed between 1 and 3

    screen.blit(font.render("Skoor: " + str(skoor), True, (255, 255, 0)), (10, 10))  # draw the score in yellow at top-left
    screen.blit(font.render("← → : move",           True, (255, 255, 255)), (10, 44))  # draw the controls hint in white below score

    pygame.display.flip()  # update the display so everything drawn this frame becomes visible

# --- Game Over screen ---
while True:  # loop forever until the player chooses to quit
    screen.fill((0, 0, 0))  # fill the screen with solid black
    screen.blit(font_big.render("GAME OVER", True, (255, 0, 0)),             (160, 150))  # draw "GAME OVER" in red
    screen.blit(font.render("Skoor: " + str(skoor), True, (255, 255, 255)),  (240, 250))  # show the final score in white
    screen.blit(font.render("Press ESC to quit",    True, (180, 180, 180)),  (190, 310))  # show the quit instruction in grey
    pygame.display.flip()  # update the display to show the game over screen

    for event in pygame.event.get():  # check for any events
        if event.type == pygame.QUIT:  # if the window close button is clicked
            sys.exit()  # exit the program
        if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:  # if ESC key is pressed
            sys.exit()  # exit the program

    # draw red car
    screen.blit(punane_auto, (redX, redY))
    red_rect = punane_auto.get_rect()
    red_rect.topleft = (redX, redY)

    # draw and move blue cars
    for i in range(len(autod)):
        screen.blit(sinine_auto, (autod[i][0], autod[i][1]))
        autod[i][1] += autod[i][2]

        blue_rect = sinine_auto.get_rect()
        blue_rect.topleft = (autod[i][0], autod[i][1])

        if red_rect.colliderect(blue_rect):
            gameover = True

        if autod[i][1] > screenY:
            skoor += 1
            autod[i][1] = random.randint(-300, -50)
            autod[i][2] = random.randint(2, 5)

    # display score and controls hint
    screen.blit(font.render("Skoor: " + str(skoor), True, (255, 255, 0)), (10, 10))
    screen.blit(font.render("← → : move", True, (255, 255, 255)), (10, 44))

    pygame.display.flip()

# --- Game Over screen ---
while True:
    screen.fill((0, 0, 0))
    screen.blit(font_big.render("GAME OVER", True, (255, 0, 0)),        (160, 150))
    screen.blit(font.render("Skoor: " + str(skoor), True, (255, 255, 255)), (240, 250))
    screen.blit(font.render("Press ESC to quit", True, (180, 180, 180)),  (190, 310))
    pygame.display.flip()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            sys.exit()
        if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
            sys.exit()
